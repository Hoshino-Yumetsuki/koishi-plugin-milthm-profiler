{
  "name": "koishi-plugin-milthm-profiler",
  "description": "Milthm 查分器",
  "version": "1.1.21",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.cjs",
      "import": "./lib/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "convert": "uv run  convert_milthm_assets.py",
    "build": "rimraf lib && yarn rolldown -c rolldown.config.js",
    "publish": "yarn npm publish",
    "lint": "oxlint",
    "lint-fix": "oxlint --fix && oxfmt"
  },
  "license": "MPL-2.0",
  "homepage": "https://github.com/Hoshino-Yumetsuki/koishi-plugin-milthm-profiler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hoshino-Yumetsuki/koishi-plugin-milthm-profiler"
  },
  "keywords": [
    "Milthm",
    "koishi",
    "plugin"
  ],
  "peerDependencies": {
    "koishi": "^4.17.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "koishi": "^4.18.11",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.1",
    "rolldown-plugin-dts": "^0.25.2",
    "typescript": "^6.0.3"
  },
  "koishi": {
    "description": {
      "zh": "Milthm 查分器",
      "en": "Milthm Profiler",
      "ja": "Milthm プロファイラー"
    }
  },
  "dependencies": {
    "@takumi-rs/helpers": "^1.8.5",
    "@takumi-rs/wasm": "^1.8.5",
    "wasm-vips": "^0.0.18"
  }
}
